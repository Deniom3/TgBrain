# ======================================================================
# TELEGRAM MESSAGE SUMMARIZER - КОНФИГУРАЦИЯ
# ======================================================================
# Этот файл содержит настройки для всех провайдеров LLM.
# Активный провайдер выбирается в LLM_ACTIVE_PROVIDER.
# ======================================================================

# ==================== Telegram ====================
# Telegram API credentials (получить на https://my.telegram.org)
# ВНИМАНИЕ: TG_API_ID и TG_API_HASH сохраняются в БД при первом запуске.
# При последующих запусках значения загружаются из БД (таблица telegram_auth).
# Изменения в .env обновляют настройки в БД при каждом запуске.
#
# ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ:
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
#
# НЕОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ:
# TG_PHONE_NUMBER=+7XXXXXXXXXX  # Для классической авторизации (не для QR)
#
# TG_SESSION_PATH удалён — сессия хранится в БД (session_data)
#
# ==================== Chat Management ====================
# Параметры для начальной инициализации чатов (опционально):
# TG_CHAT_ENABLE=-1001234567890,-1009876543210  # Включить чаты для мониторинга при старте
# TG_CHAT_DISABLE=-1001111111111                # Отключить чаты от мониторинга при старте
#
# Если параметры не указаны, используются настройки из базы данных (таблица chat_settings)
# Управление чатами через API: GET/POST /api/v1/settings/chats

# ==================== API Authentication ====================
# Ключ для защиты API endpoints. Передаётся в заголовке X-API-Key.
# Если не установлен — все endpoints публичны (режим локальной разработки).
# Минимальная длина: 16 символов.
#
# Сгенерировать ключ (Linux/macOS):
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Сгенерировать ключ (PowerShell):
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
# API_KEY=

# ==================== Database ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tg_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
# Полный URL подключения (опционально, генерируется автоматически если не указан)
# DB_URL=postgresql://postgres:your_secure_password_here@localhost:5432/tg_db

# ==================== Ollama (Embeddings) ====================
# Используется для векторизации сообщений (RAG)
# Активный провайдер для эмбеддингов: ollama, lm-studio, gemini, openrouter
OLLAMA_EMBEDDING_PROVIDER=ollama

# Ollama настройки
OLLAMA_EMBEDDING_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_EMBEDDING_DIM=768  # Опционально: размерность определяется автоматически от сервера
OLLAMA_EMBEDDING_MAX_RETRIES=3
OLLAMA_EMBEDDING_TIMEOUT=30

# ==================== LM Studio (Embeddings) ====================
# Настройки для LM Studio API
LM_STUDIO_EMBEDDING_URL=http://localhost:1234
LM_STUDIO_EMBEDDING_MODEL=text-embedding-model
LM_STUDIO_EMBEDDING_DIM=768
LM_STUDIO_EMBEDDING_API_KEY=
LM_STUDIO_EMBEDDING_MAX_RETRIES=3
LM_STUDIO_EMBEDDING_TIMEOUT=30
LM_STUDIO_EMBEDDING_NORMALIZE=false

# ==================== Gemini (Embeddings) ====================
# Настройки для Google Gemini API
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_EMBEDDING_DIM=768
GEMINI_EMBEDDING_MAX_RETRIES=3
GEMINI_EMBEDDING_TIMEOUT=30
GEMINI_EMBEDDING_NORMALIZE=false

# ==================== OpenRouter (Embeddings) ====================
# Настройки для OpenRouter API
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_EMBEDDING_DIM=1536
OPENROUTER_EMBEDDING_MAX_RETRIES=3
OPENROUTER_EMBEDDING_TIMEOUT=30
OPENROUTER_EMBEDDING_NORMALIZE=false
OPENROUTER_EMBEDDING_BATCH_SIZE=20

# ==================== Docker (опционально) ====================
# При запуске в Docker используйте эти настройки:
# DB_HOST=db  # имя сервиса в docker-compose.yml
# DB_PORT=5432
# DB_NAME=tg_db
# DB_USER=postgres
# DB_PASSWORD=secure_password_here  # используйте в docker-compose.yml
# OLLAMA_EMBEDDING_URL=http://host.docker.internal:11434
# TG_SESSION_PATH=/app/sessions
# Для Linux в docker-compose.yml добавьте:
#   extra_hosts:
#     - "host.docker.internal:host-gateway"

# ======================================================================
# LLM ПРОВАЙДЕРЫ - КОНФИГУРАЦИЯ
# ======================================================================
# Выберите активный провайдер в LLM_ACTIVE_PROVIDER.
# Для каждого провайдера укажите API ключ, URL и модель.
# Настройте fallback провайдеров для автоматического переключения.
# ======================================================================

# --- Активный провайдер ---
# Доступные значения: gemini, openrouter, ollama, lm-studio
LLM_ACTIVE_PROVIDER=gemini

# --- Fallback провайдеры ---
# Список резервных провайдеров через запятую (приоритет по порядку)
# Используется при недоступности основного провайдера
LLM_FALLBACK_PROVIDERS=openrouter,gemini

# --- Автоматический fallback ---
# Автоматически переключаться на fallback если локальный провайдер недоступен
LLM_AUTO_FALLBACK=true

# --- Таймаут проверки провайдера ---
# Время ожидания ответа от провайдера в секундах
LLM_FALLBACK_TIMEOUT=10

# ======================================================================
# Google Gemini
# ======================================================================
# Получить API ключ: https://aistudio.google.com/apikey
# Free tier модели: gemini-2.5-flash, gemini-2.5-flash-lite
# Rate limits (free): 15 RPM / 1M TPM / 1500 запросов в день
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# ======================================================================
# OpenRouter
# ======================================================================
# Получить API ключ: https://openrouter.ai/settings/keys
# Доступ к 300+ моделям через единый API
# Модель "auto" автоматически выбирает лучшую модель
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=auto

# ======================================================================
# Ollama (локально)
# ======================================================================
# Локальный сервер Ollama (не требует API ключа)
# Модели загружаются через: ollama pull <model_name>
# Популярные модели: deepseek-coder:6.7b, qwen2.5:72b, llama3.1:8b
OLLAMA_LLM_ENABLED=true
OLLAMA_LLM_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=deepseek-coder:6.7b

# ======================================================================
# LM Studio (локально)
# ======================================================================
# Локальный сервер LM Studio (не требует API ключа)
# Модели загружаются через интерфейс LM Studio
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# ======================================================================
# Application Settings
# ======================================================================
LOG_LEVEL=INFO
SUMMARY_DEFAULT_HOURS=24
SUMMARY_MAX_MESSAGES=50
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
